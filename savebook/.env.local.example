# ===================== Mongodb URI ============================
MONGODB_URI=mongodb+srv://admin:root@cluster0.wqlwpqn.mongodb.net/

# ===================== Access Token related ===================
ACCESS_TOKEN_SECRET=access_token_secret
ACCESS_TOKEN_EXPIRY=access_token_secret

# ===================== E2E Encryption =========================
# NOTE: Changing this value will NOT break existing notes.
# Notes are encrypted client-side with a per-user master key.
# This secret is only used to protect the master-key save API.
# (No server-side encryption secret is needed for E2E — keys live in the browser)

# ===================== Cloudinary =============================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===================== Github =============================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===================== Email =============================
SUPPROT_EMAIL=your_email_address
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email_address
SMTP_PASS='your_app_pass'